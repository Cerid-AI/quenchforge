[submodule "llama.cpp"]
	path = llama.cpp
	url = https://github.com/ggml-org/llama.cpp.git
	# Shallow clone — the rebase-upstream action deepens the clone on demand
	# when it needs to format-patch against historical refs. Operators who
	# need the full history can run: git submodule update --init --recursive
	#   --depth=0 -- llama.cpp
	shallow = true
[submodule "whisper.cpp"]
	path = whisper.cpp
	url = https://github.com/ggml-org/whisper.cpp.git
[submodule "sd.cpp"]
	path = sd.cpp
	url = https://github.com/leejet/stable-diffusion.cpp.git
[submodule "bark.cpp"]
	path = bark.cpp
	url = https://github.com/PABannier/bark.cpp.git
