+    // Quenchforge patch 0003: choose the `_fb` LayerNorm fallback when the
+    // device's simdgroup-reduction kernels are unsafe (non-Apple Metal).
+    // RMSNorm doesn't have an `_fb` template yet — chat correctness held
+    // through the v0.6.x cycle without it, suggesting RMSNorm's
+    // simd_*-using path is incidentally tolerable on AMD-Mac. If a chat
+    // regression surfaces, add an `_fb` template for RMSNorm in
+    // ggml-metal.metal and extend this gating to the RMS_NORM branch.
+    const bool has_sg_reduce = ggml_metal_device_get_props(
+        ggml_metal_library_get_device(lib))->has_simdgroup_reduction;
+    const char * norm_fb = has_sg_reduce ? "" : "_fb";
